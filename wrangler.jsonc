{
	"main": "dist/_worker.js/index.js",
	"name": "walden-a",
  "compatibility_date": "2026-01-23",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist"
	},
	"observability": {
    "enabled": true
  },
  "vars": {
    "BASIC_AUTH_ENABLED": "true",
    "BASIC_AUTH_USER": "admin",
    "BASIC_AUTH_PASS": "password"
  }
}