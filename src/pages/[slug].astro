---
// Página de detalle de experiencia — prerender estático.
// Flujo:
//   1. En build, getStaticPaths() pide TODAS las experiencias a Strapi.
//   2. Por cada una crea una ruta /{slug} con su HTML pre-generado.
//   3. La experiencia + el listado se pasan como props (sin refetch).
//   4. Para reflejar cambios del CMS → rebuild manual.
//
// Si /algo-slug da 404 es que Strapi no devolvió ese slug cuando
// se ejecutó el build. Revisa el log "[experiencias] X rutas …".

export const prerender = true;

import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/ui/Button.astro';
import DynamicIcon from '../components/DynamicIcon';
import {
	getAllExperiences,
	getImageUrl,
	type StrapiExperience,
	type StrapiImage,
} from '../lib/data';
import { fillExperienceWithMock } from '../lib/experiences-mock';
import { contactData, siteSettings } from '../lib/mock-data';

export async function getStaticPaths() {
	// Astro ejecuta getStaticPaths en scope aislado: no tiene
	// acceso a variables del módulo, por eso las definimos aquí.
	const RESERVED_SLUGS = new Set(['about', 'blog', 'api', 'rss.xml']);

	const experiences = await getAllExperiences();
	const routes = experiences.filter((e) => !RESERVED_SLUGS.has(e.slug));

	return routes.map((experience) => ({
		params: { slug: experience.slug },
		props: {
			experience,
			allExperiences: experiences,
		},
	}));
}

interface Props {
	experience: StrapiExperience;
	allExperiences: StrapiExperience[];
}

const { experience: rawExperience, allExperiences } = Astro.props;

// Mergea datos reales con el mock (rellena campos que aún
// no estén definidos en Strapi).
const experience = fillExperienceWithMock(rawExperience);

// Primer detail → icono + imagen de cabecera
const primaryDetail = experience.details?.[0];
const heroImage: StrapiImage | null = primaryDetail?.image ?? null;

// Para el hero usamos la imagen original (máxima calidad) como src,
// igual que hace Hero.astro con getStrapiImageDefaultSrc. El srcset
// permite al navegador elegir un formato más ligero en móvil.
const heroImageUrl = heroImage?.url ?? getImageUrl(heroImage);

// "Otras experiencias": excluimos la actual y cogemos 3
const others = allExperiences
	.filter((e) => e.slug !== experience.slug)
	.slice(0, 3);

// Helpers imagen
const getSrcset = (image: StrapiImage | null): string | undefined => {
	if (!image?.formats) return undefined;
	const parts: string[] = [];
	if (image.formats.small?.url) parts.push(`${image.formats.small.url} 500w`);
	if (image.formats.medium?.url) parts.push(`${image.formats.medium.url} 750w`);
	if (image.formats.large?.url) parts.push(`${image.formats.large.url} 1000w`);
	if (image.url) parts.push(`${image.url} 1920w`);
	return parts.length > 0 ? parts.join(', ') : undefined;
};
const getAlt = (image: StrapiImage | null, fallback: string): string =>
	image?.alternativeText || fallback;

const shortDescription = primaryDetail?.description ?? '';

const whatsappHref =`https://wa.me/${contactData.whatsapp}?text=Hola%2C%20me%20gustar%C3%ADa%20reservar%20la%20experiencia%20de%20` +
	encodeURIComponent(experience.name);

const pageTitle = `${experience.name} — ${siteSettings.title}`;
const pageDescription = experience.longDescription || shortDescription || siteSettings.description;
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead
			title={pageTitle}
			description={pageDescription}
			siteName={siteSettings.title}
			ogType="article"
			preloadImageHref={heroImageUrl?.startsWith('http') ? heroImageUrl : undefined}
		/>
	</head>
	<body class="min-h-screen bg-background">
		<Header siteTitle={siteSettings.title} />

		<main>
			{/* Hero */}
			<section class="relative h-[70vh] min-h-[500px] flex items-end overflow-hidden">
				<div class="absolute inset-0">
					<img
						src={heroImageUrl}
						srcset={getSrcset(heroImage)}
						sizes="100vw"
						alt={getAlt(heroImage, experience.name)}
						class="absolute inset-0 w-full h-full object-cover object-center"
						fetchpriority="high"
					/>
					<div
						class="absolute inset-0"
						style="background: linear-gradient(to top, hsl(var(--forest)) 0%, hsl(var(--forest) / 0.6) 50%, hsl(var(--forest) / 0.2) 100%);"
					/>
				</div>
				<div class="relative z-10 container mx-auto px-6 pb-16 md:pb-24">
					<a
						href="/"
						class="inline-flex items-center gap-2 font-body text-sm mb-6 transition-colors"
						style="color: hsl(var(--cream) / 0.8);"
					>
						<DynamicIcon name="arrow-left" size={16} />
						Volver al inicio
					</a>
					<div class="flex items-center gap-3 mb-4">
						<div
							class="w-12 h-12 rounded-xl backdrop-blur-sm flex items-center justify-center"
							style="background-color: hsl(var(--cream) / 0.15);"
						>
							<DynamicIcon
								name={primaryDetail?.icon ?? 'mountain'}
								size={22}
								color="hsl(var(--cream))"
							/>
						</div>
						<p
							class="font-body text-sm tracking-[0.2em] uppercase"
							style="color: hsl(var(--cream) / 0.85);"
						>
							{experience.tagline}
						</p>
					</div>
					<h1
						class="font-heading text-5xl md:text-7xl max-w-3xl leading-tight"
						style="color: hsl(var(--cream));"
					>
						{experience.name}
					</h1>
				</div>
			</section>

			{/* Content */}
			<section class="py-20 md:py-28">
				<div class="container mx-auto px-6">
					<div class="grid lg:grid-cols-3 gap-12 max-w-6xl mx-auto">
						{/* Main column */}
						<div class="lg:col-span-2 space-y-12">
							<div>
								<p
									class="font-body text-sm tracking-[0.2em] uppercase mb-4"
									style="color: hsl(var(--ocean));"
								>
									La experiencia
								</p>
								<p class="font-body text-foreground text-lg leading-relaxed mb-6">
									{experience.longDescription}
								</p>
								{shortDescription && shortDescription !== experience.longDescription && (
									<p class="font-body text-muted-foreground leading-relaxed">
										{shortDescription}
									</p>
								)}
							</div>

							{experience.highlights.length > 0 && (
								<div>
									<h2 class="font-heading text-3xl text-foreground mb-6">
										Lo que vivirás
									</h2>
									<ul class="space-y-3">
										{experience.highlights.map((h) => (
											<li class="flex items-start gap-3">
												<span
													class="mt-1 w-5 h-5 rounded-full flex items-center justify-center shrink-0"
													style="background-color: hsl(var(--ocean) / 0.1);"
												>
													<DynamicIcon
														name="check"
														size={12}
														color="hsl(var(--ocean))"
														strokeWidth={3}
													/>
												</span>
												<span class="font-body text-foreground/90 leading-relaxed">
													{h.text}
												</span>
											</li>
										))}
									</ul>
								</div>
							)}

							{experience.includes.length > 0 && (
								<div>
									<h2 class="font-heading text-3xl text-foreground mb-6">
										Qué incluye
									</h2>
									<div class="grid sm:grid-cols-2 gap-3">
										{experience.includes.map((item) => (
											<div
												class="flex items-center gap-3 p-4 rounded-xl"
												style="background-color: hsl(var(--secondary) / 0.4);"
											>
												<DynamicIcon
													name="check"
													size={16}
													color="hsl(var(--forest))"
													className="shrink-0"
												/>
												<span class="font-body text-sm text-foreground/90">
													{item.text}
												</span>
											</div>
										))}
									</div>
								</div>
							)}
						</div>

						{/* Sidebar */}
						<aside class="lg:col-span-1">
							<div
								class="sticky top-28 rounded-2xl border bg-card shadow-card p-6 md:p-8"
								style="border-color: hsl(var(--border));"
							>
								<div
									class="flex items-baseline gap-2 mb-6 pb-6 border-b"
									style="border-color: hsl(var(--border));"
								>
									<span
										class="font-heading text-4xl"
										style="color: hsl(var(--ocean));"
									>
										{experience.price}
									</span>
									<span class="font-body text-sm text-muted-foreground">
										/ persona
									</span>
								</div>

								<ul class="space-y-4 mb-8">
									<li class="flex items-center gap-3">
										<DynamicIcon
											name="clock"
											size={18}
											color="hsl(var(--ocean))"
											className="shrink-0"
										/>
										<div>
											<p class="font-body text-xs text-muted-foreground">
												Duración
											</p>
											<p class="font-body text-sm text-foreground">
												{experience.duration}
											</p>
										</div>
									</li>
									<li class="flex items-center gap-3">
										<DynamicIcon
											name="activity"
											size={18}
											color="hsl(var(--ocean))"
											className="shrink-0"
										/>
										<div>
											<p class="font-body text-xs text-muted-foreground">
												Dificultad
											</p>
											<p class="font-body text-sm text-foreground">
												{experience.difficulty}
											</p>
										</div>
									</li>
									<li class="flex items-center gap-3">
										<DynamicIcon
											name="users"
											size={18}
											color="hsl(var(--ocean))"
											className="shrink-0"
										/>
										<div>
											<p class="font-body text-xs text-muted-foreground">
												Grupo
											</p>
											<p class="font-body text-sm text-foreground">
												{experience.groupSize}
											</p>
										</div>
									</li>
								</ul>

								<Button
									href={whatsappHref}
									variant="ocean"
									size="lg"
									class="w-full"
									target="_blank"
									rel="noopener noreferrer"
								>
									<DynamicIcon name="message-circle" size={18} />
									Reservar por WhatsApp
								</Button>
								<p class="font-body text-xs text-muted-foreground text-center mt-4">
									Reserva con 10€, el resto el día de la actividad
								</p>
							</div>
						</aside>
					</div>
				</div>
			</section>

			{/* Other experiences */}
			{others.length > 0 && (
				<section
					class="py-20 md:py-24"
					style="background-color: hsl(var(--secondary) / 0.3);"
				>
					<div class="container mx-auto px-6">
						<div class="max-w-6xl mx-auto">
							<h2 class="font-heading text-3xl md:text-4xl text-foreground mb-10 text-center">
								Otras experiencias
							</h2>
							<div class="grid md:grid-cols-3 gap-6">
								{others.map((other) => {
									const otherDetail = other.details?.[0];
									const otherImg = otherDetail?.image ?? null;
									return (
										<a
											href={`/${other.slug}`}
											class="group relative aspect-[4/5] rounded-2xl overflow-hidden shadow-card hover:shadow-elevated transition-all duration-500 block"
										>
											<img
												src={getImageUrl(otherImg, 'medium')}
												srcset={getSrcset(otherImg)}
												sizes="(max-width: 768px) 100vw, 33vw"
												alt={getAlt(otherImg, other.name)}
												class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
												loading="lazy"
											/>
											<div
												class="absolute inset-0"
												style="background: linear-gradient(to top, hsl(var(--forest) / 0.9) 0%, hsl(var(--forest) / 0.3) 60%, transparent 100%);"
											/>
											<div class="absolute bottom-0 left-0 right-0 p-6">
												<DynamicIcon
													name={otherDetail?.icon ?? 'mountain'}
													size={20}
													color="hsl(var(--cream) / 0.8)"
													className="mb-2"
												/>
												<h3
													class="font-heading text-2xl"
													style="color: hsl(var(--cream));"
												>
													{other.name}
												</h3>
											</div>
										</a>
									);
								})}
							</div>
						</div>
					</div>
				</section>
			)}
		</main>

		<Footer siteTitle={siteSettings.title} />
	</body>
</html>
