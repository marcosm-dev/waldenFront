---
import DynamicIcon from './DynamicIcon';
import type { StrapiFilosofia, StrapiImage } from '../lib/data';

interface Props {
	philosophy: StrapiFilosofia;
}

const { philosophy } = Astro.props;
const { column1, column2 } = philosophy;

const getImageUrl = (image: StrapiImage | null): string => {
	if (!image) return '';
	return image.formats?.medium?.url || image.formats?.large?.url || image.url;
};
---

<section id="filosofia" class="py-24 md:py-32 bg-background">
	<div class="container mx-auto px-6">
		<div class="max-w-6xl mx-auto">
			<div class="grid lg:grid-cols-2 gap-16 items-center">
				<!-- Column 1: Text Content -->
				<div>
					{column1.subtitle && (
						<p class="font-body text-ocean text-sm tracking-[0.2em] uppercase mb-4">
							{column1.subtitle}
						</p>
					)}
					{column1.title && (
						<h2 class="font-heading text-4xl md:text-5xl text-foreground mb-6 leading-tight">
							{column1.title}
						</h2>
					)}
					{column1.description && (
						<p class="font-body text-muted-foreground text-lg leading-relaxed mb-8">
							{column1.description}
						</p>
					)}
					<div class="grid sm:grid-cols-2 gap-6">
						{column1.items.map((item) => (
							<div class="flex items-start gap-4 p-4 rounded-xl bg-secondary/50 hover:bg-secondary transition-colors duration-300">
								<div class="p-2 rounded-lg bg-ocean/10">
									<DynamicIcon
										name={item.icon}
										size={24}
										className="text-ocean"
									/>
								</div>
								<div>
									<h4 class="font-heading text-lg text-foreground mb-1">
										{item.title}
									</h4>
									<p class="font-body text-sm text-muted-foreground">
										{item.description}
									</p>
								</div>
							</div>
						))}
					</div>
				</div>

				<!-- Column 2: Visual Element -->
				<div class="relative">
					<div class="absolute -top-8 -right-8 w-64 h-64 bg-ocean/10 rounded-full blur-3xl"></div>
					<div class="absolute -bottom-8 -left-8 w-48 h-48 bg-terracotta/10 rounded-full blur-3xl"></div>

					{column2.image ? (
						<div class="relative rounded-3xl overflow-hidden shadow-card border border-border">
							<img
								src={getImageUrl(column2.image)}
								alt={column2.image.alternativeText || column2.title || ''}
								class="w-full h-auto object-cover"
								loading="lazy"
							/>
						</div>
					) : (
						<div class="relative bg-card rounded-3xl p-8 md:p-12 shadow-card border border-border">
							{column2.title && (
								<blockquote class="font-heading text-2xl md:text-3xl text-foreground italic leading-relaxed mb-6">
									"{column2.title}"
								</blockquote>
							)}
							<div class="flex items-center gap-4">
								<div class="w-12 h-12 rounded-full bg-ocean/20 flex items-center justify-center">
									<span class="font-heading text-xl text-ocean">W</span>
								</div>
								<div>
									{column2.subtitle && (
										<p class="font-body font-medium text-foreground">
											{column2.subtitle}
										</p>
									)}
									{column2.description && (
										<p class="font-body text-sm text-muted-foreground">
											{column2.description}
										</p>
									)}
								</div>
							</div>
						</div>
					)}
				</div>
			</div>
		</div>
	</div>
</section>
