---
interface PricingExperience {
	id: number;
	name: string;
	price: string;
	description: string;
}

interface PricingDetail {
	icon: "calendar" | "users" | "credit-card";
	title: string;
	description: string;
}

interface Props {
	subtitle?: string;
	title?: string;
	description?: string;
	experiences?: PricingExperience[];
	details?: PricingDetail[];
}

const {
	subtitle = "Cómo participar",
	title = "Elige tu experiencia",
	description = "Todas las experiencias incluyen comida porque compartir mesa forma parte esencial de la aventura.",
	experiences = [
		{ id: 1, name: "Caminata + comida", price: "30", description: "Rutas por volcanes y pinares con paella o asadero incluido" },
		{ id: 2, name: "Kayak + comida", price: "47,50", description: "Travesía costera en kayak con comida al aire libre" },
		{ id: 3, name: "Paddle surf + comida", price: "47,50", description: "Navegación sobre el agua para todos los niveles con comida" },
		{ id: 4, name: "Caminata + kayak + comida", price: "55", description: "Jornada completa combinando tierra y mar" },
		{ id: 5, name: "Caminata + paddle surf + comida", price: "55", description: "Aventura doble con senderismo y paddle surf" },
	],
	details = [
		{ icon: "calendar", title: "Sábados y domingos", description: "Actividades en fin de semana" },
		{ icon: "users", title: "4 a 8 personas", description: "Grupos íntimos garantizados" },
		{ icon: "credit-card", title: "Reserva con 10 €", description: "El resto el día de la actividad" },
	],
} = Astro.props;
---

<section id="pricing" class="py-24 md:py-32 bg-background">
	<div class="container mx-auto px-6">
		<div class="max-w-4xl mx-auto">
			<!-- Header -->
			<div class="text-center mb-16">
				<p class="font-body text-ocean text-sm tracking-[0.2em] uppercase mb-4">
					{subtitle}
				</p>
				<h2 class="font-heading text-4xl md:text-5xl lg:text-6xl text-foreground mb-6">
					{title}
				</h2>
				<p class="font-body text-muted-foreground text-lg max-w-2xl mx-auto">
					{description}
				</p>
			</div>

			<!-- Accordion Pricing -->
			<div class="pricing-accordion space-y-4 mb-16">
				{experiences.map((exp, index) => (
					<div
						class="pricing-item group rounded-2xl border border-border bg-card hover:shadow-card transition-all duration-300"
						data-index={index}
					>
						<button
							class="pricing-trigger w-full flex items-center justify-between p-6 text-left focus:outline-none focus-visible:ring-2 focus-visible:ring-ocean/50 focus-visible:ring-offset-2 rounded-2xl"
							aria-expanded="false"
						>
							<h3 class="font-heading text-xl text-foreground pr-4">
								{exp.name}
							</h3>
							<div class="flex items-center gap-4 shrink-0">
								<div class="text-right">
									<span class="font-heading text-2xl text-ocean">
										{exp.price}€
									</span>
									<p class="font-body text-xs text-muted-foreground">
										por persona
									</p>
								</div>
								<span class="pricing-chevron w-8 h-8 rounded-full bg-secondary flex items-center justify-center transition-transform duration-300">
									<svg class="w-5 h-5 text-muted-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="m6 9 6 6 6-6"/>
									</svg>
								</span>
							</div>
						</button>

						<div class="pricing-panel">
							<div class="px-6 pb-6">
								<div class="pt-4 border-t border-border/50">
									<p class="font-body text-muted-foreground leading-relaxed mb-4">
										{exp.description}
									</p>
									<div class="flex items-center gap-2 text-sm text-forest">
										<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
											<path d="M20 6 9 17l-5-5"/>
										</svg>
										<span class="font-body">Comida incluida</span>
									</div>
								</div>
							</div>
						</div>
					</div>
				))}
			</div>

			<!-- Organization Details -->
			<div class="bg-secondary/30 rounded-3xl p-8 md:p-12">
				<div class="grid md:grid-cols-3 gap-8 mb-10">
					{details.map((detail) => (
						<div class="text-center">
							<div class="w-14 h-14 rounded-2xl bg-ocean/10 flex items-center justify-center mx-auto mb-4">
								{detail.icon === "calendar" && (
									<svg class="text-ocean" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
										<path d="M8 2v4"/>
										<path d="M16 2v4"/>
										<rect width="18" height="18" x="3" y="4" rx="2"/>
										<path d="M3 10h18"/>
									</svg>
								)}
								{detail.icon === "users" && (
									<svg class="text-ocean" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
										<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
										<circle cx="9" cy="7" r="4"/>
										<path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
										<path d="M16 3.13a4 4 0 0 1 0 7.75"/>
									</svg>
								)}
								{detail.icon === "credit-card" && (
									<svg class="text-ocean" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
										<rect width="20" height="14" x="2" y="5" rx="2"/>
										<line x1="2" x2="22" y1="10" y2="10"/>
									</svg>
								)}
							</div>
							<h4 class="font-heading text-lg text-foreground mb-1">
								{detail.title}
							</h4>
							<p class="font-body text-sm text-muted-foreground">
								{detail.description}
							</p>
						</div>
					))}
				</div>

				<div class="text-center">
					<p class="font-body text-muted-foreground mb-6">
						¿Tienes alguna pregunta o quieres reservar tu plaza?
					</p>
					<a
						href="#contact"
						class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-base font-medium h-12 px-8 py-3 transition-all duration-300 bg-ocean text-white hover:bg-ocean/90 font-body shadow-md hover:shadow-lg"
					>
						Reservar experiencia
					</a>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	/* Accordion panel animation */
	.pricing-panel {
		display: grid;
		grid-template-rows: 0fr;
		transition: grid-template-rows 0.3s ease-out;
	}

	.pricing-panel > div {
		overflow: hidden;
	}

	.pricing-item.expanded .pricing-panel {
		grid-template-rows: 1fr;
	}

	/* Expanded state */
	.pricing-item.expanded {
		border-color: hsl(var(--ocean) / 0.3);
		box-shadow: 0 8px 30px -8px hsl(var(--forest) / 0.15);
	}

	.pricing-item.expanded .pricing-chevron {
		transform: rotate(180deg);
		background: hsl(var(--ocean) / 0.1);
	}

	.pricing-item.expanded .pricing-chevron svg {
		color: hsl(var(--ocean));
	}
</style>

<script>
	const accordion = document.querySelector('.pricing-accordion');
	const items = accordion?.querySelectorAll('.pricing-item');

	items?.forEach(item => {
		const trigger = item.querySelector('.pricing-trigger');
		const panel = item.querySelector('.pricing-panel');

		trigger?.addEventListener('click', () => {
			const isExpanded = item.classList.contains('expanded');

			// Close all other items
			items.forEach(otherItem => {
				if (otherItem !== item && otherItem.classList.contains('expanded')) {
					otherItem.classList.remove('expanded');
					otherItem.querySelector('.pricing-trigger')?.setAttribute('aria-expanded', 'false');
				}
			});

			// Toggle current item
			if (isExpanded) {
				item.classList.remove('expanded');
				trigger.setAttribute('aria-expanded', 'false');
			} else {
				item.classList.add('expanded');
				trigger.setAttribute('aria-expanded', 'true');
			}
		});
	});
</script>
