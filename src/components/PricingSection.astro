---
interface PricingExperience {
  id: number;
  name: string;
  price: string;
  description: string;
  icon: "mountain" | "waves" | "leaf";
  tags: string[];
}

interface PricingDetail {
  icon: "calendar" | "users" | "credit-card";
  title: string;
  description: string;
}

interface Props {
  subtitle?: string;
  title?: string;
  description?: string;
  experiences?: PricingExperience[];
  details?: PricingDetail[];
}

const {
  subtitle = "Cómo participar",
  title = "Elige tu experiencia",
  description = "Todas las experiencias incluyen comida porque compartir mesa forma parte esencial de la aventura.",
  experiences = [
    { id: 1, name: "Caminata + comida", price: "30", description: "Rutas por volcanes y pinares con paella o asadero incluido", icon: "mountain", tags: ["Tierra", "Comida incluida"] },
    { id: 2, name: "Kayak + comida", price: "47,50", description: "Travesía costera en kayak con comida al aire libre", icon: "waves", tags: ["Mar", "Comida incluida"] },
    { id: 3, name: "Paddle surf + comida", price: "47,50", description: "Navegación sobre el agua para todos los niveles con comida", icon: "waves", tags: ["Mar", "Comida incluida"] },
    { id: 4, name: "Caminata + kayak + comida", price: "55", description: "Jornada completa combinando tierra y mar", icon: "leaf", tags: ["Tierra + Mar", "Día completo", "Comida incluida"] },
    { id: 5, name: "Caminata + paddle surf + comida", price: "55", description: "Aventura doble con senderismo y paddle surf", icon: "leaf", tags: ["Tierra + Mar", "Día completo", "Comida incluida"] },
  ],
  details = [
    { icon: "calendar", title: "Sábados y domingos", description: "Actividades en fin de semana" },
    { icon: "users", title: "4 a 8 personas", description: "Grupos íntimos garantizados" },
    { icon: "credit-card", title: "Reserva con 10 €", description: "El resto el día de la actividad" },
  ],
} = Astro.props;
---

<section id="precios" class="py-24 md:py-32 bg-background relative overflow-hidden">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-20 right-0 w-96 h-96 rounded-full blur-3xl" style="background: hsl(var(--ocean) / 0.03);" />
    <div class="absolute bottom-20 left-0 w-80 h-80 rounded-full blur-3xl" style="background: hsl(var(--forest) / 0.03);" />
  </div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="max-w-3xl mx-auto">
      <!-- Header -->
      <div class="text-center mb-16">
        <p class="font-body text-ocean text-sm tracking-[0.2em] uppercase mb-4">
          {subtitle}
        </p>
        <h2 class="font-heading text-4xl md:text-5xl lg:text-6xl text-foreground mb-6">
          {title}
        </h2>
        <p class="font-body text-muted-foreground text-lg max-w-2xl mx-auto">
          {description}
        </p>
      </div>

      <!-- Accordion Pricing -->
      <div class="pricing-accordion space-y-3 mb-16">
        {experiences.map((exp, index) => (
          <div
            class="pricing-item rounded-2xl border border-border bg-card transition-all duration-500 ease-out"
            data-index={index}
          >
            <button
              class="pricing-trigger w-full flex items-center justify-between p-5 md:p-6 text-left focus:outline-none focus-visible:ring-2 focus-visible:ring-ocean/50 focus-visible:ring-offset-2 rounded-2xl group"
              aria-expanded="false"
            >
              <div class="flex items-center gap-4">
                <div class="pricing-icon w-10 h-10 rounded-xl flex items-center justify-center transition-all duration-300 bg-ocean/10 text-ocean shrink-0">
                  {exp.icon === "mountain" && (
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="m8 3 4 8 5-5 5 15H2L8 3z"/>
                    </svg>
                  )}
                  {exp.icon === "waves" && (
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M2 6c.6.5 1.2 1 2.5 1C7 7 7 5 9.5 5c2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/>
                      <path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/>
                      <path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/>
                    </svg>
                  )}
                  {exp.icon === "leaf" && (
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/>
                      <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/>
                    </svg>
                  )}
                </div>
                <h3 class="font-heading text-lg md:text-xl text-foreground">
                  {exp.name}
                </h3>
              </div>

              <div class="pricing-chevron w-8 h-8 rounded-full bg-secondary flex items-center justify-center transition-all duration-300 shrink-0">
                <svg class="w-4 h-4 text-muted-foreground transition-colors duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="m6 9 6 6 6-6"/>
                </svg>
              </div>
            </button>

            <div class="pricing-panel">
              <div class="overflow-hidden">
                <div class="px-5 md:px-6 pb-5 md:pb-6">
                  <div class="pt-3 ml-14 border-t border-border/50">
                    <p class="font-body text-muted-foreground leading-relaxed mb-4 mt-4">
                      {exp.description}
                    </p>

                    <div class="flex flex-wrap items-center gap-2 mb-4">
                      {exp.tags.map((tag) => (
                        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-body" style="background: hsl(var(--forest) / 0.05); color: hsl(var(--forest) / 0.8);">
                          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M20 6 9 17l-5-5"/>
                          </svg>
                          {tag}
                        </span>
                      ))}
                    </div>

                    <!-- Price inside panel -->
                    <div class="flex items-center justify-between pt-4 border-t border-border/30">
                      <span class="font-body text-sm text-muted-foreground">Precio por persona</span>
                      <span class="font-heading text-2xl md:text-3xl text-ocean">{exp.price}€</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Organization Details -->
      <div class="bg-secondary/30 rounded-3xl p-8 md:p-12">
        <div class="grid md:grid-cols-3 gap-8 mb-10">
          {details.map((detail) => (
            <div class="text-center">
              <div class="w-14 h-14 rounded-2xl bg-ocean/10 flex items-center justify-center mx-auto mb-4">
                {detail.icon === "calendar" && (
                  <svg class="text-ocean" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M8 2v4"/><path d="M16 2v4"/>
                    <rect width="18" height="18" x="3" y="4" rx="2"/>
                    <path d="M3 10h18"/>
                  </svg>
                )}
                {detail.icon === "users" && (
                  <svg class="text-ocean" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/>
                    <path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
                    <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                  </svg>
                )}
                {detail.icon === "credit-card" && (
                  <svg class="text-ocean" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect width="20" height="14" x="2" y="5" rx="2"/>
                    <line x1="2" x2="22" y1="10" y2="10"/>
                  </svg>
                )}
              </div>
              <h4 class="font-heading text-lg text-foreground mb-1">
                {detail.title}
              </h4>
              <p class="font-body text-sm text-muted-foreground">
                {detail.description}
              </p>
            </div>
          ))}
        </div>

        <div class="text-center">
          <p class="font-body text-muted-foreground mb-6">
            ¿Tienes alguna pregunta o quieres reservar tu plaza?
          </p>
          <a
            href="#contacto"
            class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-base font-medium h-12 px-8 py-3 transition-all duration-300 bg-ocean text-white hover:bg-ocean/90 font-body shadow-md hover:shadow-lg"
            style="color: white;"
          >
            Reservar experiencia
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .pricing-panel {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.4s ease-out;
  }

  .pricing-item.expanded .pricing-panel {
    grid-template-rows: 1fr;
  }

  .pricing-item.expanded {
    border-color: hsl(var(--ocean) / 0.3);
    background: linear-gradient(to bottom, hsl(var(--card)), hsl(var(--secondary) / 0.2));
    box-shadow: 0 8px 30px -8px hsl(var(--forest) / 0.15);
  }

  .pricing-item:not(.expanded):hover {
    border-color: hsl(var(--ocean) / 0.15);
    box-shadow: 0 4px 20px -4px hsl(var(--forest) / 0.1);
  }

  .pricing-item.expanded .pricing-icon {
    background: hsl(var(--ocean));
    color: hsl(var(--cream));
    transform: scale(1.1);
  }

  .pricing-item.expanded .pricing-chevron {
    background: hsl(var(--ocean) / 0.1);
    transform: rotate(180deg);
  }

  .pricing-item.expanded .pricing-chevron svg {
    color: hsl(var(--ocean));
  }
</style>

<script>
  const accordion = document.querySelector('.pricing-accordion');
  const items = accordion?.querySelectorAll('.pricing-item');

  items?.forEach(item => {
    const trigger = item.querySelector('.pricing-trigger');

    trigger?.addEventListener('click', () => {
      const isExpanded = item.classList.contains('expanded');

      items.forEach(otherItem => {
        if (otherItem !== item) {
          otherItem.classList.remove('expanded');
          otherItem.querySelector('.pricing-trigger')?.setAttribute('aria-expanded', 'false');
        }
      });

      if (isExpanded) {
        item.classList.remove('expanded');
        trigger.setAttribute('aria-expanded', 'false');
      } else {
        item.classList.add('expanded');
        trigger.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
