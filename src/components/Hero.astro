---
import "swiper/css";
import "swiper/css/pagination";
import "../lib/effects/effect-super-flow.css";

import type { StrapiSlide } from "../lib/data";

interface Props {
	title: string;
	subtitle: string | null;
	description: string | null;
	ctaPrimary: string | null;
	ctaSecondary: string | null;
	ctaPrimaryHref?: string | null;
	ctaSecondaryHref?: string | null;
	slides: StrapiSlide[];
}

const {
	title,
	subtitle,
	description,
	ctaPrimary,
	ctaSecondary,
	ctaPrimaryHref,
	ctaSecondaryHref,
	slides,
} = Astro.props;

// Obtener URL principal de imagen
const getImageUrl = (slide: StrapiSlide): string => {
	if (!slide.image) return "/images/01.jpg";
	return slide.image.url;
};

// Generar srcset para imágenes responsive
const getImageSrcset = (slide: StrapiSlide): string | undefined => {
	if (!slide.image?.formats) return undefined;

	const formats = slide.image.formats;
	const srcsetParts: string[] = [];

	if (formats.small?.url) srcsetParts.push(`${formats.small.url} 500w`);
	if (formats.medium?.url) srcsetParts.push(`${formats.medium.url} 750w`);
	if (formats.large?.url) srcsetParts.push(`${formats.large.url} 1000w`);
	if (slide.image.url) srcsetParts.push(`${slide.image.url} 1920w`);

	return srcsetParts.length > 0 ? srcsetParts.join(', ') : undefined;
};

const imageSizes = "100vw";

const getImageAlt = (slide: StrapiSlide): string => {
	return slide.image?.alternativeText || slide.title;
};
---

<section class="hero-section relative min-h-screen flex items-center justify-center overflow-hidden">
	<!-- Swiper Background Fullscreen -->
	<div class="swiper swiper-hero absolute inset-0 z-0">
		<div class="swiper-wrapper">
			{slides.map((slide, index) => (
				<div class="swiper-slide" data-slide-index={index}>
					<div class="super-flow-image">
						<img
							src={getImageUrl(slide)}
							srcset={getImageSrcset(slide)}
							sizes={imageSizes}
							alt={getImageAlt(slide)}
							class="w-full h-full object-cover"
							loading={index === 0 ? "eager" : "lazy"}
							fetchpriority={index === 0 ? "high" : "auto"}
						/>
					</div>
				</div>
			))}
		</div>
		<div class="swiper-pagination"></div>
	</div>

	<!-- Gradient Overlay -->
	<div class="absolute inset-0 gradient-hero z-1"></div>

	<!-- Content -->
	<div class="relative z-10 container mx-auto px-6 text-center">
		<div class="max-w-4xl mx-auto">
			<!-- Slide subtitle - dinámico (cambia con cada slide) -->
			<p
				id="hero-slide-subtitle"
				class="font-body text-cream/80 text-sm tracking-[0.3em] uppercase mb-4 transition-all duration-500"
			>
				{slides[0]?.subtitle || ""}
			</p>

			<!-- Slide title - dinámico (cambia con cada slide) -->
			<h2
				id="hero-slide-title"
				class="font-heading text-2xl md:text-3xl lg:text-4xl text-cream/90 font-medium leading-tight mb-10 transition-all duration-500"
			>
				{slides[0]?.title || ""}
			</h2>

			<!-- Subtítulo fijo -->
			<p
				class="font-body text-cream/90 text-sm tracking-[0.3em] uppercase mb-6 animate-fade-in"
				style="animation-delay: 0.2s;"
			>
				{subtitle}
			</p>

			<!-- Título principal -->
			<h1
				class="font-heading text-5xl md:text-7xl lg:text-8xl text-cream font-medium leading-tight mb-6 animate-fade-in"
				style="animation-delay: 0.4s;"
			>
				{title}
			</h1>

			<!-- Descripción -->
			<p
				class="font-body text-cream/90 text-lg md:text-xl max-w-2xl mx-auto mb-10 leading-relaxed animate-fade-in"
				style="animation-delay: 0.6s;"
			>
				{description}
			</p>

			<!-- CTAs -->
			<div
				class="flex flex-col sm:flex-row gap-4 justify-center animate-fade-in"
				style="animation-delay: 0.8s;"
			>
				<a
					href={ctaPrimaryHref}
					class="btn-hero-primary inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-base font-medium h-14 px-10 py-4 transition-all duration-300 font-body shadow-lg"
				>
					{ctaPrimary}
				</a>
				<a
					href={ctaSecondaryHref}
					class="btn-hero-secondary inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-base font-medium h-14 px-10 py-4 transition-all duration-300 border-2 font-body"
				>
					{ctaSecondary}
				</a>
			</div>
		</div>
	</div>

	<!-- Scroll Indicator -->
	<a
		href="#experiencias"
		class="absolute bottom-10 left-1/2 -translate-x-1/2 hover:text-cream transition-colors animate-float z-10 text-white!"
		aria-label="Scroll hacia experiencias"
	>
		<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<path d="m6 9 6 6 6-6"/>
		</svg>
	</a>
</section>

<!-- Datos de slides para JavaScript -->
<script define:vars={{ slidesData: slides }}>
	window.heroSlidesData = slidesData;
</script>

<style>
	.hero-section {
		min-height: 100vh;
		min-height: 100dvh;
		height: 100vh;
		height: 100dvh;
	}

	/* Botones CTA del Hero */
	.btn-hero-primary {
		background-color: hsl(var(--terracotta));
		color: #ffffff;
	}

	.btn-hero-primary:hover {
		background-color: hsl(var(--terracotta) / 0.9);
	}

	.btn-hero-secondary {
		background-color: transparent;
		border-color: hsl(var(--cream));
		color: hsl(var(--cream));
	}

	.btn-hero-secondary:hover {
		background-color: hsl(var(--cream) / 0.1);
	}

	/* Swiper fullscreen background */
	.swiper-hero {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
	}

	.swiper-hero .swiper-wrapper {
		height: 100%;
	}

	.swiper-hero .swiper-slide {
		height: 100%;
		width: 100%;
	}

	/* Imagen fullscreen */
	.swiper-hero .super-flow-image {
		width: 100%;
		height: 100%;
		position: relative;
	}

	.swiper-hero .super-flow-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
	}

	/* Ocultar contenido del super-flow effect */
	.swiper-hero .super-flow-content {
		display: none !important;
	}

	/* Pagination styling */
	.swiper-hero :global(.swiper-pagination) {
		bottom: 100px !important;
	}

	.swiper-hero :global(.swiper-pagination-bullet) {
		background: rgba(255, 255, 255, 0.5);
		opacity: 1;
		width: 10px;
		height: 10px;
	}

	.swiper-hero :global(.swiper-pagination-bullet-active) {
		background: hsl(var(--terracotta));
		width: 30px;
		border-radius: 5px;
	}

	/* Animación de fade in */
	@keyframes fadeIn {
		from {
			opacity: 0;
			transform: translateY(20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.animate-fade-in {
		opacity: 0;
		animation: fadeIn 0.8s ease-out forwards;
	}

	/* Animación flotante para scroll indicator */
	@keyframes float {
		0%, 100% {
			transform: translateX(-50%) translateY(0);
		}
		50% {
			transform: translateX(-50%) translateY(-10px);
		}
	}

	.animate-float {
		animation: float 2s ease-in-out infinite;
	}
</style>

<script>
	import Swiper from "swiper";
	import { Autoplay, Pagination } from "swiper/modules";
	import EffectSuperFlow from "../lib/effects/effect-super-flow.esm.js";

	// Elementos del DOM para títulos dinámicos
	const slideTitle = document.getElementById('hero-slide-title');
	const slideSubtitle = document.getElementById('hero-slide-subtitle');

	// Obtener datos de slides
	const slidesData = (window as any).heroSlidesData || [];

	// Función para actualizar texto con animación
	const updateSlideText = (index: number) => {
		const slide = slidesData[index];
		if (!slide || !slideTitle || !slideSubtitle) return;

		// Fade out
		slideTitle.style.opacity = '0';
		slideTitle.style.transform = 'translateY(-10px)';
		slideSubtitle.style.opacity = '0';
		slideSubtitle.style.transform = 'translateY(-10px)';

		// Update text after fade out
		setTimeout(() => {
			slideTitle.textContent = slide.title || '';
			slideSubtitle.textContent = slide.subtitle || '';

			// Fade in
			slideTitle.style.opacity = '1';
			slideTitle.style.transform = 'translateY(0)';
			slideSubtitle.style.opacity = '1';
			slideSubtitle.style.transform = 'translateY(0)';
		}, 300);
	};

	// Inicializar Swiper con opciones extendidas para el efecto personalizado
	const swiper = new Swiper(".swiper-hero", {
		direction: "horizontal",
		modules: [EffectSuperFlow, Autoplay, Pagination],
		effect: "super-flow" as any,
		slidesPerView: 1,
		loop: true,
		pagination: {
			el: ".swiper-pagination",
			clickable: true,
		},
		speed: 1000,
		grabCursor: true,
		autoplay: {
			delay: 5000,
			disableOnInteraction: false,
		},
		// Opciones del efecto Super Flow (tipado personalizado)
		...({
			superFlowEffect: {
				fragments: 3,
				fragmentBlur: true,
				fragmentBorderWidth: 2,
				scaleDuration: 4000,
				contentOffset: 5,
				contentScale: 1.2,
				mainImageScale: 1.1,
				level1Scale: 1.15,
				level2Scale: 1.2,
				level3Scale: 1.25,
			},
		} as any),
	});

	// Escuchar cambio de slide
	swiper.on('slideChange', () => {
		updateSlideText(swiper.realIndex);
	});
</script>
