---
import "swiper/css";
import "swiper/css/pagination";
import "swiper/css/effect-fade";

import { Image } from "astro:assets";
import img01 from "../assets/images/01.jpg";
import img02 from "../assets/images/02.jpg";
import img03 from "../assets/images/03.jpg";
import img04 from "../assets/images/04.jpg";
import img05 from "../assets/images/05.jpg";

const slides = [
	{ image: img01, alt: "Kayak en la costa de Gran Canaria" },
	{ image: img02, alt: "Caminata por los pinares" },
	{ image: img03, alt: "Paddle surf al atardecer" },
	{ image: img04, alt: "Comida al aire libre" },
	{ image: img05, alt: "Aventura en la naturaleza" },
];
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
	<!-- Swiper Background -->
	<div class="swiper-hero absolute inset-0">
		<div class="swiper-wrapper">
			{slides.map((slide) => (
				<div class="swiper-slide">
					<Image
						src={slide.image}
						alt={slide.alt}
						class="w-full h-full object-cover"
						widths={[640, 1024, 1920]}
						sizes="100vw"
					/>
				</div>
			))}
		</div>
	</div>

	<!-- Gradient Overlay -->
	<div class="absolute inset-0 gradient-hero z-[1]"></div>

	<!-- Content -->
	<div class="relative z-10 container mx-auto px-6 text-center">
		<div class="max-w-4xl mx-auto">
			<p
				class="font-body text-cream/90 text-sm tracking-[0.3em] uppercase mb-6 animate-fade-in"
				style="animation-delay: 0.2s; animation-fill-mode: both;"
			>
				Gran Canaria, España
			</p>
			<h1
				class="font-heading text-5xl md:text-7xl lg:text-8xl text-cream font-medium leading-tight mb-6 animate-fade-in"
				style="animation-delay: 0.4s; animation-fill-mode: both;"
			>
				Experiencias al aire libre para disfrutar sin prisas
			</h1>
			<p
				class="font-body text-cream/90 text-lg md:text-xl max-w-2xl mx-auto mb-10 leading-relaxed animate-fade-in"
				style="animation-delay: 0.6s; animation-fill-mode: both;"
			>
				Creamos experiencias al aire libre diseñadas para quienes desean
				desconectar de la rutina, disfrutar de la naturaleza y compartir
				buenos momentos en un entorno tranquilo y cuidado.
			</p>
			<div
				class="flex flex-col sm:flex-row gap-4 justify-center animate-fade-in"
				style="animation-delay: 0.8s; animation-fill-mode: both;"
			>
				<a
					href="#experiences"
					class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-base font-medium h-12 px-8 py-3 transition-all duration-300 bg-cream text-forest hover:bg-cream/90 font-body"
				>
					Descubre nuestras experiencias
				</a>
				<a
					href="#contact"
					class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-base font-medium h-12 px-8 py-3 transition-all duration-300 border-2 border-cream/60 text-cream hover:bg-cream hover:text-forest font-body"
				>
					Contactar
				</a>
			</div>
		</div>
	</div>

	<!-- Swiper Pagination -->
	<div class="swiper-pagination-hero absolute bottom-24 left-1/2 -translate-x-1/2 z-10"></div>

	<!-- Scroll Indicator -->
	<a
		href="#experiences"
		class="absolute bottom-10 left-1/2 -translate-x-1/2 text-cream/70 hover:text-cream transition-colors animate-float z-10"
		aria-label="Scroll hacia experiencias"
	>
		<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<path d="m6 9 6 6 6-6"/>
		</svg>
	</a>
</section>

<style>
	.swiper-hero {
		width: 100%;
		height: 100%;
	}

	.swiper-hero .swiper-slide {
		width: 100%;
		height: 100%;
	}

	.swiper-hero .swiper-slide img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	/* Pagination styles */
	.swiper-pagination-hero {
		display: flex;
		gap: 8px;
		justify-content: center;
	}

	.swiper-pagination-hero :global(.swiper-pagination-bullet) {
		width: 10px;
		height: 10px;
		background: hsl(var(--cream) / 0.4);
		border-radius: 50%;
		opacity: 1;
		transition: all 0.3s ease;
	}

	.swiper-pagination-hero :global(.swiper-pagination-bullet-active) {
		background: hsl(var(--cream));
		transform: scale(1.2);
	}

	@keyframes float {
		0%, 100% {
			transform: translateX(-50%) translateY(0);
		}
		50% {
			transform: translateX(-50%) translateY(-10px);
		}
	}

	.animate-float {
		animation: float 2s ease-in-out infinite;
	}
</style>

<script>
	import Swiper from "swiper";
	import { Autoplay, Pagination, EffectFade } from "swiper/modules";

	new Swiper(".swiper-hero", {
		modules: [Autoplay, Pagination, EffectFade],
		effect: "fade",
		fadeEffect: {
			crossFade: true
		},
		slidesPerView: 1,
		loop: true,
		speed: 1500,
		autoplay: {
			delay: 5000,
			disableOnInteraction: false,
		},
		pagination: {
			el: ".swiper-pagination-hero",
			clickable: true,
		},
	});
</script>
