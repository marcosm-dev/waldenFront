---
import DynamicIcon from './DynamicIcon';
import type { StrapiExperience, StrapiImage } from '../lib/data';

interface Props {
	experiences: StrapiExperience[];
}

const { experiences } = Astro.props;

const getImageUrl = (image: StrapiImage | null): string => {
	if (!image) return '/images/placeholder.jpg';
	return image.formats?.medium?.url || image.formats?.large?.url || image.url;
};

const getImageSrcset = (image: StrapiImage | null): string | undefined => {
	if (!image?.formats) return undefined;
	const parts: string[] = [];
	if (image.formats.small?.url) parts.push(`${image.formats.small.url} 500w`);
	if (image.formats.medium?.url) parts.push(`${image.formats.medium.url} 750w`);
	if (image.formats.large?.url) parts.push(`${image.formats.large.url} 1000w`);
	if (image.url) parts.push(`${image.url} 1920w`);
	return parts.length > 0 ? parts.join(', ') : undefined;
};

const getImageAlt = (image: StrapiImage | null, fallback: string): string => {
	return image?.alternativeText || fallback;
};
---

<section id="experiencias" class="py-24 md:py-32 gradient-sand">
	<div class="container mx-auto px-6">
		<div class="text-center mb-16 md:mb-20">
			<p class="font-body text-ocean text-sm tracking-[0.2em] uppercase mb-4">
				Nuestras experiencias
			</p>
			<h2 class="font-heading text-4xl md:text-5xl lg:text-6xl text-foreground mb-6">
				Elige tu aventura
			</h2>
			<p class="font-body text-muted-foreground text-lg max-w-2xl mx-auto leading-relaxed">
				Puedes elegir una actividad concreta o combinar varias en el mismo
				día. Todas las experiencias incluyen comida.
			</p>
		</div>

		<div class="grid md:grid-cols-2 gap-8 max-w-6xl mx-auto">
			{experiences.map((experience, index) => {
				const detail = experience.details[0];
				if (!detail) return null;

				return (
					<div
						class="group relative overflow-hidden rounded-2xl shadow-card hover:shadow-elevated transition-all duration-500 cursor-pointer"
						style={`animation-delay: ${index * 0.1}s`}
					>
						<div class="relative aspect-4/3 overflow-hidden">
							<img
								src={getImageUrl(detail.image)}
								srcset={getImageSrcset(detail.image)}
								sizes="(max-width: 768px) 100vw, 50vw"
								alt={getImageAlt(detail.image, experience.name)}
								class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
								loading="lazy"
							/>
						</div>
						<div class="absolute inset-0 bg-linear-to-t from-forest/90 via-forest/40 to-transparent" />
						<div class="absolute bottom-0 left-0 right-0 p-6 md:p-8">
							<div class="flex items-center gap-3 mb-3">
								<DynamicIcon
									name={detail.icon}
									size={24}
									className="text-ocean-light"
								/>
								<h3 class="font-heading text-2xl md:text-3xl text-cream">
									{experience.name}
								</h3>
							</div>
							<p class="font-body text-cream/85 leading-relaxed">
								{detail.description}
							</p>
						</div>
					</div>
				);
			})}
		</div>
	</div>
</section>
