---
import { SITE_LOGO } from '../consts';

const navLinks = [
	{ href: "#experiences", label: "Experiencias" },
	{ href: "#philosophy", label: "Filosofía" },
	{ href: "#pricing", label: "Precios" },
];
---

<header
	id="main-header"
	class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 bg-transparent py-6"
>
	<div class="container mx-auto px-6 flex items-center justify-between">
		<a href="#" class="flex items-center gap-3">
			<img
				src={SITE_LOGO}
				alt="Walden Adventures"
				class="header-logo w-10 h-10 rounded-full object-cover transition-all duration-300"
			/>
			<span
				class="header-title font-heading text-2xl font-semibold transition-colors duration-300 text-cream"
			>
				Walden Adventures
			</span>
			<span
				class="header-subtitle text-sm font-body tracking-widest transition-colors duration-300 text-cream/80"
			>
				GC
			</span>
		</a>

		<!-- Desktop Navigation -->
		<nav class="hidden md:flex items-center gap-8">
			{navLinks.map((link) => (
				<a
					href={link.href}
					class="nav-link font-body text-sm tracking-wide transition-all duration-300 hover:opacity-70 text-cream"
				>
					{link.label}
				</a>
			))}
			<a
				href="#pricing"
				class="btn-reservar inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium h-9 px-4 py-2 transition-all duration-300 border border-cream/60 text-cream hover:bg-cream hover:text-forest"
			>
				Reservar
			</a>
		</nav>

		<!-- Mobile Menu Button -->
		<button
			id="mobile-menu-btn"
			class="md:hidden"
			aria-label="Abrir menú"
		>
			<svg
				id="menu-icon"
				class="menu-icon text-cream transition-colors duration-300"
				width="24"
				height="24"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
			>
				<line x1="4" x2="20" y1="12" y2="12"></line>
				<line x1="4" x2="20" y1="6" y2="6"></line>
				<line x1="4" x2="20" y1="18" y2="18"></line>
			</svg>
			<svg
				id="close-icon"
				class="menu-icon hidden text-cream transition-colors duration-300"
				width="24"
				height="24"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
			>
				<path d="M18 6 6 18"></path>
				<path d="m6 6 12 12"></path>
			</svg>
		</button>
	</div>

	<!-- Mobile Menu -->
	<div
		id="mobile-menu"
		class="md:hidden hidden absolute top-full left-0 right-0 bg-background/98 backdrop-blur-md shadow-card animate-fade-in"
	>
		<nav class="container mx-auto px-6 py-6 flex flex-col gap-4">
			{navLinks.map((link) => (
				<a
					href={link.href}
					class="mobile-nav-link font-body text-foreground py-2 border-b border-border"
				>
					{link.label}
				</a>
			))}
			<a
				href="#pricing"
				class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium bg-primary text-primary-foreground hover:bg-primary/90 h-10 px-4 py-2 mt-2 transition-colors"
			>
				Reservar
			</a>
		</nav>
	</div>
</header>

<script>
	const header = document.getElementById('main-header');
	const mobileMenuBtn = document.getElementById('mobile-menu-btn');
	const mobileMenu = document.getElementById('mobile-menu');
	const menuIcon = document.getElementById('menu-icon');
	const closeIcon = document.getElementById('close-icon');
	const headerTitle = document.querySelector('.header-title');
	const headerSubtitle = document.querySelector('.header-subtitle');
	const navLinks = document.querySelectorAll('.nav-link');
	const menuIcons = document.querySelectorAll('.menu-icon');
	const btnReservar = document.querySelector('.btn-reservar');
	const mobileNavLinks = document.querySelectorAll('.mobile-nav-link');

	let isMenuOpen = false;

	// Handle scroll effect
	const handleScroll = () => {
		const isScrolled = window.scrollY > 50;

		if (isScrolled) {
			header?.classList.remove('bg-transparent', 'py-6');
			header?.classList.add('bg-background/95', 'backdrop-blur-md', 'shadow-soft', 'py-4');

			headerTitle?.classList.remove('text-cream');
			headerTitle?.classList.add('text-forest');

			headerSubtitle?.classList.remove('text-cream/80');
			headerSubtitle?.classList.add('text-muted-foreground');

			navLinks.forEach(link => {
				link.classList.remove('text-cream');
				link.classList.add('text-foreground');
			});

			menuIcons.forEach(icon => {
				icon.classList.remove('text-cream');
				icon.classList.add('text-foreground');
			});

			btnReservar?.classList.remove('border-cream/60', 'text-cream', 'hover:bg-cream', 'hover:text-forest');
			btnReservar?.classList.add('bg-primary', 'text-primary-foreground', 'hover:bg-primary/90', 'border-transparent');
		} else {
			header?.classList.add('bg-transparent', 'py-6');
			header?.classList.remove('bg-background/95', 'backdrop-blur-md', 'shadow-soft', 'py-4');

			headerTitle?.classList.add('text-cream');
			headerTitle?.classList.remove('text-forest');

			headerSubtitle?.classList.add('text-cream/80');
			headerSubtitle?.classList.remove('text-muted-foreground');

			navLinks.forEach(link => {
				link.classList.add('text-cream');
				link.classList.remove('text-foreground');
			});

			menuIcons.forEach(icon => {
				icon.classList.add('text-cream');
				icon.classList.remove('text-foreground');
			});

			btnReservar?.classList.add('border-cream/60', 'text-cream', 'hover:bg-cream', 'hover:text-forest');
			btnReservar?.classList.remove('bg-primary', 'text-primary-foreground', 'hover:bg-primary/90', 'border-transparent');
		}
	};

	// Handle mobile menu toggle
	const toggleMenu = () => {
		isMenuOpen = !isMenuOpen;

		if (isMenuOpen) {
			mobileMenu?.classList.remove('hidden');
			menuIcon?.classList.add('hidden');
			closeIcon?.classList.remove('hidden');
		} else {
			mobileMenu?.classList.add('hidden');
			menuIcon?.classList.remove('hidden');
			closeIcon?.classList.add('hidden');
		}
	};

	// Close mobile menu when clicking a link
	mobileNavLinks.forEach(link => {
		link.addEventListener('click', () => {
			isMenuOpen = false;
			mobileMenu?.classList.add('hidden');
			menuIcon?.classList.remove('hidden');
			closeIcon?.classList.add('hidden');
		});
	});

	window.addEventListener('scroll', handleScroll);
	mobileMenuBtn?.addEventListener('click', toggleMenu);

	// Initial check
	handleScroll();
</script>
