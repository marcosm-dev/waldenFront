---
interface Props {
	siteTitle?: string;
}

const { siteTitle = "Walden Adventures" } = Astro.props;

const navLinks = [
	{ href: "#experiences", label: "Experiencias" },
	{ href: "#philosophy", label: "Filosofía" },
	{ href: "#pricing", label: "Precios" },
	{ href: "#testimonials", label: "Opiniones" },
	{ href: "#contact", label: "Contacto" },
];
---

<header
	id="main-header"
	class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 bg-transparent py-6"
>
	<div class="container mx-auto px-6 flex items-center justify-between">
		<a href="#" class="flex items-center gap-3">
			<!-- Logo - Icono naranja con borde naranja -->
			<div class="header-logo w-10 h-10 rounded-full bg-transparent border-2 border-terracotta flex items-center justify-center transition-all duration-300">
				<svg
					class="logo-icon"
					width="20"
					height="20"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2.5"
					stroke-linecap="round"
					stroke-linejoin="round"
				>
					<path d="m8 3 4 8 5-5 5 15H2L8 3z"></path>
				</svg>
			</div>
			<span
				class="header-title font-heading text-2xl font-semibold transition-colors duration-300 text-cream drop-shadow-sm"
			>
				{siteTitle}
			</span>
			<span
				class="header-subtitle text-sm font-body tracking-widest transition-colors duration-300 text-cream/80"
			>
				GC
			</span>
		</a>

		<!-- Desktop Navigation -->
		<nav class="hidden md:flex items-center gap-8">
			{navLinks.map((link) => (
				<a
					href={link.href}
					class="nav-link font-body text-sm tracking-wide transition-all duration-300 hover:opacity-70 text-cream drop-shadow-sm"
				>
					{link.label}
				</a>
			))}
			<a
				href="#contact"
				class="btn-reservar inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium h-9 px-4 py-2 transition-all duration-300 bg-terracotta text-cream hover:bg-terracotta/90 font-body shadow-md"
			>
				Reservar
			</a>
		</nav>

		<!-- Mobile Menu Button -->
		<button
			id="mobile-menu-btn"
			class="md:hidden"
			aria-label="Abrir menú"
		>
			<svg
				id="menu-icon"
				class="menu-icon text-cream drop-shadow-sm transition-colors duration-300"
				width="24"
				height="24"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
			>
				<line x1="4" x2="20" y1="12" y2="12"></line>
				<line x1="4" x2="20" y1="6" y2="6"></line>
				<line x1="4" x2="20" y1="18" y2="18"></line>
			</svg>
			<svg
				id="close-icon"
				class="menu-icon hidden text-cream drop-shadow-sm transition-colors duration-300"
				width="24"
				height="24"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
			>
				<path d="M18 6 6 18"></path>
				<path d="m6 6 12 12"></path>
			</svg>
		</button>
	</div>

	<!-- Mobile Menu -->
	<div
		id="mobile-menu"
		class="md:hidden hidden absolute top-full left-0 right-0 bg-cream/98 backdrop-blur-md shadow-card"
	>
		<nav class="container mx-auto px-6 py-6 flex flex-col gap-4">
			{navLinks.map((link) => (
				<a
					href={link.href}
					class="mobile-nav-link font-body text-forest py-2 border-b border-forest/10"
				>
					{link.label}
				</a>
			))}
			<a
				href="#contact"
				class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium bg-terracotta text-cream hover:bg-terracotta/90 h-10 px-4 py-2 mt-2 transition-colors font-body"
			>
				Reservar
			</a>
		</nav>
	</div>
</header>

<style>
	/* Text shadow for better readability over images */
	.drop-shadow-sm {
		text-shadow: 0 1px 3px rgba(0, 0, 0, 0.4);
	}

	/* Logo icon color */
	.logo-icon {
		color: #C4704F; /* terracotta */
	}

	/* Scrolled state logo */
	.header-scrolled .logo-icon {
		color: #C4704F;
	}
</style>

<script>
	const header = document.getElementById('main-header');
	const mobileMenuBtn = document.getElementById('mobile-menu-btn');
	const mobileMenu = document.getElementById('mobile-menu');
	const menuIcon = document.getElementById('menu-icon');
	const closeIcon = document.getElementById('close-icon');
	const headerLogo = document.querySelector('.header-logo') as HTMLElement;
	const headerTitle = document.querySelector('.header-title');
	const headerSubtitle = document.querySelector('.header-subtitle');
	const navLinks = document.querySelectorAll('.nav-link');
	const menuIcons = document.querySelectorAll('.menu-icon');
	const btnReservar = document.querySelector('.btn-reservar');
	const mobileNavLinks = document.querySelectorAll('.mobile-nav-link');

	let isMenuOpen = false;

	// Handle scroll effect
	const handleScroll = () => {
		const isScrolled = window.scrollY > 50;

		if (isScrolled) {
			header?.classList.remove('bg-transparent', 'py-6');
			header?.classList.add('bg-cream/98', 'backdrop-blur-md', 'shadow-soft', 'py-4', 'header-scrolled');

			// Logo mantiene borde naranja pero fondo cream
			headerLogo?.classList.remove('bg-transparent');
			headerLogo?.classList.add('bg-cream');

			headerTitle?.classList.remove('text-cream', 'drop-shadow-sm');
			headerTitle?.classList.add('text-forest');

			headerSubtitle?.classList.remove('text-cream/80');
			headerSubtitle?.classList.add('text-forest/60');

			navLinks.forEach(link => {
				link.classList.remove('text-cream', 'drop-shadow-sm');
				link.classList.add('text-forest');
			});

			menuIcons.forEach(icon => {
				icon.classList.remove('text-cream', 'drop-shadow-sm');
				icon.classList.add('text-forest');
			});

			// Botón reservar siempre naranja
			btnReservar?.classList.remove('shadow-md');
			btnReservar?.classList.add('shadow-sm');
		} else {
			header?.classList.add('bg-transparent', 'py-6');
			header?.classList.remove('bg-cream/98', 'backdrop-blur-md', 'shadow-soft', 'py-4', 'header-scrolled');

			// Logo transparente sobre hero
			headerLogo?.classList.add('bg-transparent');
			headerLogo?.classList.remove('bg-cream');

			headerTitle?.classList.add('text-cream', 'drop-shadow-sm');
			headerTitle?.classList.remove('text-forest');

			headerSubtitle?.classList.add('text-cream/80');
			headerSubtitle?.classList.remove('text-forest/60');

			navLinks.forEach(link => {
				link.classList.add('text-cream', 'drop-shadow-sm');
				link.classList.remove('text-forest');
			});

			menuIcons.forEach(icon => {
				icon.classList.add('text-cream', 'drop-shadow-sm');
				icon.classList.remove('text-forest');
			});

			btnReservar?.classList.add('shadow-md');
			btnReservar?.classList.remove('shadow-sm');
		}
	};

	// Handle mobile menu toggle
	const toggleMenu = () => {
		isMenuOpen = !isMenuOpen;

		if (isMenuOpen) {
			mobileMenu?.classList.remove('hidden');
			menuIcon?.classList.add('hidden');
			closeIcon?.classList.remove('hidden');
		} else {
			mobileMenu?.classList.add('hidden');
			menuIcon?.classList.remove('hidden');
			closeIcon?.classList.add('hidden');
		}
	};

	// Close mobile menu when clicking a link
	mobileNavLinks.forEach(link => {
		link.addEventListener('click', () => {
			isMenuOpen = false;
			mobileMenu?.classList.add('hidden');
			menuIcon?.classList.remove('hidden');
			closeIcon?.classList.add('hidden');
		});
	});

	window.addEventListener('scroll', handleScroll);
	mobileMenuBtn?.addEventListener('click', toggleMenu);

	// Initial check
	handleScroll();
</script>
