---
interface Props {
	siteTitle?: string;
}

const { siteTitle = "Walden Adventures" } = Astro.props;

const navLinks = [
	{ href: "#experiences", label: "Experiencias" },
	{ href: "#philosophy", label: "Filosofía" },
	{ href: "#contact", label: "Contacto" },
];
---

<header
	id="main-header"
	class="header-transparent fixed top-0 left-0 right-0 z-50 transition-all duration-500 py-6"
>
	<div class="container mx-auto px-6 flex items-center justify-between">
		<a href="#" class="flex items-center gap-3">
			<!-- Logo - Icono de montaña -->
			<div class="header-logo w-10 h-10 rounded-full border-2 flex items-center justify-center transition-all duration-300">
				<svg
					class="logo-icon"
					width="20"
					height="20"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2.5"
					stroke-linecap="round"
					stroke-linejoin="round"
				>
					<path d="m8 3 4 8 5-5 5 15H2L8 3z"></path>
				</svg>
			</div>
			<span class="header-title font-heading text-2xl font-semibold transition-colors duration-300">
				{siteTitle}
			</span>
		</a>

		<!-- Desktop Navigation -->
		<nav class="hidden md:flex items-center gap-8">
			{navLinks.map((link) => (
				<a
					href={link.href}
					class="nav-link font-body text-sm tracking-wide transition-all duration-300 hover:opacity-70"
				>
					{link.label}
				</a>
			))}
			<a
				href="#contact"
				class="btn-reservar inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium h-9 px-4 py-2 transition-all duration-300 font-body"
			>
				Reservar
			</a>
		</nav>

		<!-- Mobile Menu Button -->
		<button
			id="mobile-menu-btn"
			class="md:hidden"
			aria-label="Abrir menú"
		>
			<svg
				id="menu-icon"
				class="menu-icon transition-colors duration-300"
				width="24"
				height="24"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
			>
				<line x1="4" x2="20" y1="12" y2="12"></line>
				<line x1="4" x2="20" y1="6" y2="6"></line>
				<line x1="4" x2="20" y1="18" y2="18"></line>
			</svg>
			<svg
				id="close-icon"
				class="menu-icon hidden transition-colors duration-300"
				width="24"
				height="24"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
			>
				<path d="M18 6 6 18"></path>
				<path d="m6 6 12 12"></path>
			</svg>
		</button>
	</div>

	<!-- Mobile Menu -->
	<div
		id="mobile-menu"
		class="md:hidden hidden absolute top-full left-0 right-0 shadow-card animate-fade-in"
		style="background: hsl(var(--background) / 0.98); backdrop-filter: blur(12px);"
	>
		<nav class="container mx-auto px-6 py-6 flex flex-col gap-4">
			{navLinks.map((link) => (
				<a
					href={link.href}
					class="mobile-nav-link font-body py-2"
					style="color: hsl(var(--foreground)); border-bottom: 1px solid hsl(var(--border));"
				>
					{link.label}
				</a>
			))}
			<a
				href="#contact"
				class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-lg text-sm font-medium h-10 px-4 py-2 mt-2 transition-all duration-300 font-body"
				style="background-color: hsl(158 35% 25%); color: hsl(45 30% 97%);"
			>
				Reservar
			</a>
		</nav>
	</div>
</header>

<style>
	/* Estado inicial: transparente sobre hero (texto cream) */
	.header-transparent {
		background: transparent;
	}

	.header-transparent .header-title {
		color: hsl(var(--cream));
	}

	.header-transparent .header-subtitle {
		color: hsl(var(--cream) / 0.8);
	}

	.header-transparent .nav-link {
		color: hsl(var(--cream));
	}

	.header-transparent .menu-icon {
		color: hsl(var(--cream));
	}

	/* Botón heroOutline: borde cream, fondo transparente */
	.header-transparent .btn-reservar {
		border: 2px solid hsl(var(--cream));
		color: hsl(var(--cream));
		background: transparent;
	}

	.header-transparent .btn-reservar:hover {
		background: hsl(var(--cream) / 0.1);
	}

	/* Estado scrolled: fondo sólido */
	.header-scrolled {
		background: hsl(var(--background) / 0.95);
		backdrop-filter: blur(12px);
		box-shadow: var(--shadow-soft);
		padding-top: 1rem;
		padding-bottom: 1rem;
	}

	.header-scrolled .header-title {
		color: hsl(var(--forest));
	}

	.header-scrolled .header-subtitle {
		color: hsl(var(--muted-foreground));
	}

	.header-scrolled .nav-link {
		color: hsl(var(--foreground));
	}

	.header-scrolled .menu-icon {
		color: hsl(var(--foreground));
	}

	/* Botón scrolled: fondo terracotta (naranja) con texto blanco */
	.header-scrolled .btn-reservar {
		border: none;
		background: hsl(var(--terracotta));
		color: #ffffff;
	}

	.header-scrolled .btn-reservar:hover {
		background: hsl(var(--terracotta) / 0.9);
	}

	/* Logo icono */
	.header-transparent .header-logo {
		border-color: hsl(var(--terracotta));
		background: transparent;
	}

	.header-transparent .logo-icon {
		color: hsl(var(--terracotta));
	}

	.header-scrolled .header-logo {
		border-color: hsl(var(--terracotta));
		background: hsl(var(--cream));
	}

	.header-scrolled .logo-icon {
		color: hsl(var(--terracotta));
	}
</style>

<script>
	const header = document.getElementById('main-header');
	const mobileMenuBtn = document.getElementById('mobile-menu-btn');
	const mobileMenu = document.getElementById('mobile-menu');
	const menuIcon = document.getElementById('menu-icon');
	const closeIcon = document.getElementById('close-icon');
	const mobileNavLinks = document.querySelectorAll('.mobile-nav-link');

	let isMenuOpen = false;

	// Handle scroll effect
	const handleScroll = () => {
		const isScrolled = window.scrollY > 50;

		if (isScrolled) {
			header?.classList.remove('header-transparent', 'py-6');
			header?.classList.add('header-scrolled', 'py-4');
		} else {
			header?.classList.add('header-transparent', 'py-6');
			header?.classList.remove('header-scrolled', 'py-4');
		}
	};

	// Handle mobile menu toggle
	const toggleMenu = () => {
		isMenuOpen = !isMenuOpen;

		if (isMenuOpen) {
			mobileMenu?.classList.remove('hidden');
			menuIcon?.classList.add('hidden');
			closeIcon?.classList.remove('hidden');
		} else {
			mobileMenu?.classList.add('hidden');
			menuIcon?.classList.remove('hidden');
			closeIcon?.classList.add('hidden');
		}
	};

	// Close mobile menu when clicking a link
	mobileNavLinks.forEach(link => {
		link.addEventListener('click', () => {
			isMenuOpen = false;
			mobileMenu?.classList.add('hidden');
			menuIcon?.classList.remove('hidden');
			closeIcon?.classList.add('hidden');
		});
	});

	window.addEventListener('scroll', handleScroll);
	mobileMenuBtn?.addEventListener('click', toggleMenu);

	// Initial check
	handleScroll();
</script>
