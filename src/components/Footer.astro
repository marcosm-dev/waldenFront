---
const today = new Date();
---

<footer class="py-8 bg-foreground">
	<div class="container mx-auto px-6">
		<div class="flex flex-col md:flex-row items-center justify-between gap-4">
			<div class="flex items-center gap-2">
				<span class="font-heading text-lg text-cream">
					Walden Adventures
				</span>
				<span class="text-xs font-body tracking-widest text-cream/60">
					GC
				</span>
			</div>
			<p class="font-body text-sm text-cream/50">
				&copy; {today.getFullYear()} Walden Adventures GC. Todos los derechos reservados.
			</p>
		</div>
	</div>
</footer>
