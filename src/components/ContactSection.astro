---
import Button from "./ui/Button.astro";

// Contact Section - Diseño Lovable con fondo forest
interface Props {
	title?: string;
	subtitle?: string;
	description?: string;
	email?: string;
	phone?: string;
	whatsapp?: string;
	instagram?: string;
	location?: string;
}

const {
	title = "¿Listo para tu próxima aventura?",
	subtitle = "Contacto",
	description = "Escríbenos y cuéntanos qué experiencia te gustaría vivir. Te responderemos lo antes posible para organizar tu escapada.",
	email = "info@walden-adventures.com",
	phone = "+34 647067949",
	whatsapp = "34647067949",
	instagram = "@waldenadventuresgc",
	location = "Gran Canaria, España"
} = Astro.props;
---

<section id="contacto" class="py-24 md:py-32 bg-forest">
	<div class="container mx-auto px-6">
		<div class="max-w-4xl mx-auto text-center">
			<p class="font-body text-ocean-light text-sm tracking-[0.2em] uppercase mb-4">
				{subtitle}
			</p>
			<h2 class="contact-title font-heading text-4xl md:text-5xl lg:text-6xl text-cream mb-6">
				{title}
			</h2>
			<p class="font-body text-cream/80 text-lg max-w-2xl mx-auto mb-10 leading-relaxed">
				{description}
			</p>

			<div class="flex flex-col sm:flex-row gap-4 justify-center mb-16">
				<Button
					variant="hero"
					size="xl"
					href={`mailto:${email}`}
					title="Enviar un mensaje por email"
					class="gap-2"
				>
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
						<rect width="20" height="16" x="2" y="4" rx="2"></rect>
						<path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
					</svg>
					Enviar mensaje
				</Button>
				<Button
					variant="heroOutline"
					size="xl"
					href={`https://wa.me/${whatsapp}`}
					title={`WhatsApp ${phone}`}
					class="gap-2"
					target="_blank"
					rel="noopener noreferrer"
				>
					<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="shrink-0">
						<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
					</svg>
					Llamar ahora
				</Button>
			</div>

			<div class="grid sm:grid-cols-3 gap-8 pt-10 border-t border-cream/20">
				<!-- Ubicación -->
				<div class="text-center">
					<div class="w-12 h-12 rounded-full bg-cream/10 flex items-center justify-center mx-auto mb-4">
						<svg class="text-ocean-light" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
							<circle cx="12" cy="10" r="3"></circle>
						</svg>
					</div>
					<p class="font-body text-cream font-medium mb-1">Ubicación</p>
					<p class="font-body text-cream/70 text-sm">{location}</p>
				</div>

				<!-- Email -->
				<div class="text-center">
					<div class="w-12 h-12 rounded-full bg-cream/10 flex items-center justify-center mx-auto mb-4">
						<svg class="text-ocean-light" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<rect width="20" height="16" x="2" y="4" rx="2"></rect>
							<path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
						</svg>
					</div>
					<p class="font-body text-cream font-medium mb-1">Email</p>
					<a
						href={`mailto:${email}`}
						title={`Enviar email a ${email}`}
						class="font-body text-cream/70 text-sm hover:text-cream transition-colors"
					>
						{email}
					</a>
				</div>

				<!-- Instagram -->
				<div class="text-center">
					<div class="w-12 h-12 rounded-full bg-cream/10 flex items-center justify-center mx-auto mb-4">
						<svg class="text-ocean-light" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect>
							<path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
							<line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line>
						</svg>
					</div>
					<p class="font-body text-cream font-medium mb-1">Instagram</p>
					<a
						href="https://instagram.com/waldenadventuresgc"
						target="_blank"
						rel="noopener noreferrer"
						title={`Ver perfil de Instagram ${instagram}`}
						class="font-body text-cream/70 text-sm hover:text-cream transition-colors"
					>
						{instagram}
					</a>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.contact-title {
		text-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
	}
</style>
