---
interface Testimonial {
	id: number;
	name: string;
	location?: string;
	experience: string;
	text: string;
	rating: number;
	date?: string;
	avatar?: string;
}

interface Props {
	subtitle?: string;
	title?: string;
	description?: string;
	testimonials?: Testimonial[];
}

const {
	subtitle = "Testimonios",
	title = "Lo que dicen nuestros aventureros",
	description = "Experiencias reales de quienes han disfrutado de nuestras actividades al aire libre.",
	testimonials = [
		{
			id: 1,
			name: "María García",
			location: "Las Palmas",
			experience: "Kayak + comida",
			text: "Una experiencia increíble. El ritmo fue perfecto, sin prisas, disfrutando cada momento. La paella al final fue el broche de oro. Volveré seguro.",
			rating: 5,
			date: "Noviembre 2024",
		},
		{
			id: 2,
			name: "Carlos Rodríguez",
			location: "Telde",
			experience: "Caminata + kayak + comida",
			text: "Buscaba desconectar y lo conseguí. El grupo pequeño hace que todo sea más cercano y auténtico. Los guías súper atentos.",
			rating: 5,
			date: "Octubre 2024",
		},
		{
			id: 3,
			name: "Ana Martínez",
			location: "Madrid",
			experience: "Paddle surf + comida",
			text: "Vine de vacaciones y fue el mejor plan. Nunca había hecho paddle surf y me sentí muy cómoda. El asadero en plena naturaleza, espectacular.",
			rating: 5,
			date: "Septiembre 2024",
		},
	],
} = Astro.props;

// Función para generar estrellas
const renderStars = (rating: number) => {
	return Array(5).fill(0).map((_, i) => i < rating);
};
---

<section id="testimonios" class="py-24 md:py-32 bg-secondary/30">
	<div class="container mx-auto px-6">
		<div class="max-w-6xl mx-auto">
			<!-- Header -->
			<div class="text-center mb-16">
				<p class="font-body text-ocean text-sm tracking-[0.2em] uppercase mb-4">
					{subtitle}
				</p>
				<h2 class="font-heading text-4xl md:text-5xl lg:text-6xl text-foreground mb-6">
					{title}
				</h2>
				<p class="font-body text-muted-foreground text-lg max-w-2xl mx-auto">
					{description}
				</p>
			</div>

			<!-- Testimonials Grid -->
			<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
				{testimonials.map((testimonial) => (
					<div class="bg-card rounded-2xl p-6 md:p-8 shadow-card border border-border hover:shadow-elevated transition-all duration-300">
						<!-- Rating Stars -->
						<div class="flex gap-1 mb-4">
							{renderStars(testimonial.rating).map((filled) => (
								<svg
									class={`w-5 h-5 ${filled ? 'text-terracotta' : 'text-border'}`}
									viewBox="0 0 24 24"
									fill="currentColor"
								>
									<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
								</svg>
							))}
						</div>

						<!-- Quote -->
						<blockquote class="font-body text-foreground leading-relaxed mb-6">
							"{testimonial.text}"
						</blockquote>

						<!-- Experience Badge -->
						<div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-ocean/10 text-ocean text-sm font-body mb-4">
							<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M20 6 9 17l-5-5"></path>
							</svg>
							{testimonial.experience}
						</div>

						<!-- Author -->
						<div class="flex items-center gap-3 pt-4 border-t border-border/50">
							<div class="w-10 h-10 rounded-full bg-forest/20 flex items-center justify-center">
								<span class="font-heading text-lg text-forest">
									{testimonial.name.charAt(0)}
								</span>
							</div>
							<div>
								<p class="font-body font-medium text-foreground">
									{testimonial.name}
								</p>
								<p class="font-body text-sm text-muted-foreground">
									{testimonial.location && `${testimonial.location}`}
									{testimonial.location && testimonial.date && " · "}
									{testimonial.date}
								</p>
							</div>
						</div>
					</div>
				))}
			</div>

			<!-- CTA para dejar testimonio -->
			<div class="text-center mt-12">
				<p class="font-body text-muted-foreground mb-4">
					¿Has vivido una experiencia con nosotros?
				</p>
				<a
					href="#contacto"
					class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium h-11 px-6 py-2 transition-all duration-300 border-2 border-ocean text-ocean hover:bg-ocean hover:text-cream font-body"
				>
					<svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
					</svg>
					Comparte tu experiencia
				</a>
			</div>
		</div>
	</div>
</section>
